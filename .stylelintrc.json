{
  "extends": "stylelint-config-standard",
  "rules": {
    "custom-property-pattern": [
      "^ecdysiz-[a-z0-9]+(-[a-z0-9]+)*$",
      {
        "message": "CSS custom properties must use the ecdysiz- prefix (e.g. --ecdysiz-color-surface)."
      }
    ],
    "selector-class-pattern": [
      "^ecdysiz-[a-z0-9]+(-[a-z0-9]+)*(__[a-z0-9]+(-[a-z0-9]+)*)?(--[a-z0-9]+(-[a-z0-9]+)*)?$",
      {
        "message": "Class names must use the ecdysiz- prefix (e.g. .ecdysiz-btn, .ecdysiz-card__media, .ecdysiz-btn--primary)."
      }
    ],
    "declaration-no-important": [
      true,
      {
        "message": "!important is banned. Use @layer client to override cleanly."
      }
    ],
    "no-descending-specificity": null,
    "comment-empty-line-before": null,
    "no-duplicate-selectors": null,
    "rule-empty-line-before": null,
    "selector-not-notation": "complex",
    "media-feature-range-notation": "prefix"
  },
  "overrides": [
    {
      "files": ["theme/ecdysiz-core/assets/css/framework.css"],
      "rules": {
        "declaration-no-important": null
      }
    }
  ],
  "ignoreFiles": [
    "**/node_modules/**",
    "**/dist/**",
    "**/generated/**",
    "**/vendor/**"
  ]
}