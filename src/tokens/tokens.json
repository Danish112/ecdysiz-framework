{
  "$schema-version": "1.0.0",
  "$description": "Ecdysiz design tokens — single source of truth. Edit here only.",

  "primitives": {
    "color": {
      "white": "#ffffff",
      "black": "#0a0a0a",

      "gray-50":  "#fafafa",
      "gray-100": "#f4f4f5",
      "gray-200": "#e4e4e7",
      "gray-300": "#d4d4d8",
      "gray-400": "#a1a1aa",
      "gray-500": "#71717a",
      "gray-600": "#52525b",
      "gray-700": "#3f3f46",
      "gray-800": "#27272a",
      "gray-900": "#18181b",

      "brand-primary":   "#2563eb",
      "brand-secondary": "#7c3aed",
      "brand-accent":    "#f59e0b",

      "status-success-light": "#d1fae5",
      "status-success":       "#10b981",
      "status-success-dark":  "#065f46",

      "status-warning-light": "#fef3c7",
      "status-warning":       "#f59e0b",
      "status-warning-dark":  "#92400e",

      "status-error-light":   "#fee2e2",
      "status-error":         "#ef4444",
      "status-error-dark":    "#991b1b",

      "status-info-light":    "#dbeafe",
      "status-info":          "#3b82f6",
      "status-info-dark":     "#1e3a8a"
    },

    "typography": {
      "family-sans":    "system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
      "family-heading": "system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
      "family-mono":    "ui-monospace, 'SF Mono', Menlo, Consolas, monospace",

      "weight-regular":  "400",
      "weight-medium":   "500",
      "weight-semibold": "600",
      "weight-bold":     "700",

      "leading-tight":   "1.2",
      "leading-snug":    "1.35",
      "leading-normal":  "1.5",
      "leading-relaxed": "1.65",

      "tracking-tight":  "-0.02em",
      "tracking-normal": "0",
      "tracking-wide":   "0.02em",

      "viewport-min": "20rem",
      "viewport-max": "80rem"
    },

    "spacing": {
      "0":   "0",
      "1":   "0.5rem",
      "2":   "0.75rem",
      "3":   "1rem",
      "4":   "1.5rem",
      "5":   "2rem",
      "6":   "3rem",
      "7":   "4rem",
      "8":   "5rem",
      "9":   "7.5rem"
    },

    "radius": {
      "none": "0",
      "sm":   "0.75rem",
      "md":   "1rem",
      "lg":   "1.25rem",
      "xl":   "2rem",
      "full": "9999px"
    },

    "border-width": {
      "0":   "0",
      "thin":  "1px",
      "medium":  "2px",
      "thick": "4px"
    },

    "shadow-color": {
      "light": "rgba(0, 0, 0, 0.08)",
      "light-strong": "rgba(0, 0, 0, 0.16)",
      "dark": "rgba(0, 0, 0, 0.4)",
      "dark-strong": "rgba(0, 0, 0, 0.6)"
    },

    "motion": {
      "duration-fast":    "150ms",
      "duration-base":    "250ms",
      "duration-slow":    "400ms",

      "ease-standard":   "cubic-bezier(0.4, 0, 0.2, 1)",
      "ease-in":         "cubic-bezier(0.4, 0, 1, 1)",
      "ease-out":        "cubic-bezier(0, 0, 0.2, 1)",
      "ease-emphasized": "cubic-bezier(0.2, 0, 0, 1)"
    },

    "z-index": {
      "base":     "0",
      "raised":   "10",
      "dropdown": "100",
      "sticky":   "200",
      "header":   "300",
      "overlay":  "400",
      "modal":    "500",
      "popover":  "600",
      "toast":    "700"
    },

    "opacity": {
      "0":   "0",
      "20":  "0.2",
      "40":  "0.4",
      "60":  "0.6",
      "80":  "0.8",
      "100": "1"
    },

    "layout": {
      "content-width":     "1280px",
      "content-width-wide":"1440px",
      "side-padding":      "1.5rem",
      "side-padding-sm":   "1rem"
    },

    "breakpoint": {
      "mobile-max":   "767px",
      "tablet-min":   "768px",
      "tablet-max":   "1024px",
      "desktop-min":  "1025px",
      "desktop-max":  "1439px",
      "ultrawide-min":"1440px"
    },

    "type-size": {
      "caption-min":  "0.75rem",
      "caption-max":  "0.8125rem",
      "body-sm-min":  "0.875rem",
      "body-sm-max":  "0.9375rem",
      "body-min":     "1rem",
      "body-max":     "1.0625rem",
      "body-lg-min":  "1.125rem",
      "body-lg-max":  "1.25rem",
      "h6-min":       "1.125rem",
      "h6-max":       "1.25rem",
      "h5-min":       "1.25rem",
      "h5-max":       "1.5rem",
      "h4-min":       "1.5rem",
      "h4-max":       "1.875rem",
      "h3-min":       "1.875rem",
      "h3-max":       "2.5rem",
      "h2-min":       "2.25rem",
      "h2-max":       "3.5rem",
      "h1-min":       "2.75rem",
      "h1-max":       "4.5rem",
      "display-min":  "3.5rem",
      "display-max":  "6rem"
    }
  },

  "semantic": {
    "color": {
      "background": {
        "light": "{primitives.color.white}",
        "dark":  "{primitives.color.gray-900}"
      },
      "surface": {
        "light": "{primitives.color.white}",
        "dark":  "{primitives.color.gray-800}"
      },
      "surface-raised": {
        "light": "{primitives.color.gray-50}",
        "dark":  "{primitives.color.gray-700}"
      },

      "text": {
        "light": "{primitives.color.gray-900}",
        "dark":  "{primitives.color.gray-50}"
      },
      "text-muted": {
        "light": "{primitives.color.gray-600}",
        "dark":  "{primitives.color.gray-400}"
      },
      "text-inverse": {
        "light": "{primitives.color.white}",
        "dark":  "{primitives.color.gray-900}"
      },

      "border": {
        "light": "{primitives.color.gray-200}",
        "dark":  "{primitives.color.gray-700}"
      },
      "border-muted": {
        "light": "{primitives.color.gray-100}",
        "dark":  "{primitives.color.gray-800}"
      },

      "primary": {
        "light": "{primitives.color.brand-primary}",
        "dark":  "{primitives.color.brand-primary}"
      },
      "primary-hover": {
        "light": "{primitives.color.brand-primary}",
        "dark":  "{primitives.color.brand-primary}"
      },
      "primary-on": {
        "light": "{primitives.color.white}",
        "dark":  "{primitives.color.white}"
      },

      "secondary": {
        "light": "{primitives.color.brand-secondary}",
        "dark":  "{primitives.color.brand-secondary}"
      },
      "secondary-on": {
        "light": "{primitives.color.white}",
        "dark":  "{primitives.color.white}"
      },

      "accent": {
        "light": "{primitives.color.brand-accent}",
        "dark":  "{primitives.color.brand-accent}"
      },
      "accent-on": {
        "light": "{primitives.color.gray-900}",
        "dark":  "{primitives.color.gray-900}"
      },

      "focus-ring": {
        "light": "{primitives.color.brand-primary}",
        "dark":  "{primitives.color.brand-accent}"
      },

      "success-surface": {
        "light": "{primitives.color.status-success-light}",
        "dark":  "{primitives.color.status-success-dark}"
      },
      "success-text": {
        "light": "{primitives.color.status-success-dark}",
        "dark":  "{primitives.color.status-success-light}"
      },

      "warning-surface": {
        "light": "{primitives.color.status-warning-light}",
        "dark":  "{primitives.color.status-warning-dark}"
      },
      "warning-text": {
        "light": "{primitives.color.status-warning-dark}",
        "dark":  "{primitives.color.status-warning-light}"
      },

      "error-surface": {
        "light": "{primitives.color.status-error-light}",
        "dark":  "{primitives.color.status-error-dark}"
      },
      "error-text": {
        "light": "{primitives.color.status-error-dark}",
        "dark":  "{primitives.color.status-error-light}"
      },

      "info-surface": {
        "light": "{primitives.color.status-info-light}",
        "dark":  "{primitives.color.status-info-dark}"
      },
      "info-text": {
        "light": "{primitives.color.status-info-dark}",
        "dark":  "{primitives.color.status-info-light}"
      }
    },

    "spacing": {
      "inline-xs": "{primitives.spacing.1}",
      "inline-sm": "{primitives.spacing.2}",
      "inline-md": "{primitives.spacing.3}",
      "inline-lg": "{primitives.spacing.4}",

      "stack-xs":  "{primitives.spacing.1}",
      "stack-sm":  "{primitives.spacing.3}",
      "stack-md":  "{primitives.spacing.4}",
      "stack-lg":  "{primitives.spacing.5}",
      "stack-xl":  "{primitives.spacing.6}",

      "section-mobile":  "{primitives.spacing.7}",
      "section-tablet":  "{primitives.spacing.8}",
      "section-desktop": "{primitives.spacing.9}"
    },

    "radius": {
      "control":     "{primitives.radius.sm}",
      "card":        "{primitives.radius.md}",
      "surface":     "{primitives.radius.lg}",
      "panel":       "{primitives.radius.xl}",
      "pill":        "{primitives.radius.full}",
      "none":        "{primitives.radius.none}"
    },

    "shadow": {
      "none": {
        "light": "none",
        "dark":  "none"
      },
      "sm": {
        "light": "0 1px 2px {primitives.shadow-color.light}",
        "dark":  "0 1px 2px {primitives.shadow-color.dark}"
      },
      "md": {
        "light": "0 4px 8px {primitives.shadow-color.light}, 0 1px 2px {primitives.shadow-color.light}",
        "dark":  "0 4px 8px {primitives.shadow-color.dark}, 0 1px 2px {primitives.shadow-color.dark}"
      },
      "lg": {
        "light": "0 10px 20px {primitives.shadow-color.light}, 0 4px 8px {primitives.shadow-color.light}",
        "dark":  "0 10px 20px {primitives.shadow-color.dark-strong}, 0 4px 8px {primitives.shadow-color.dark}"
      },
      "xl": {
        "light": "0 20px 40px {primitives.shadow-color.light-strong}",
        "dark":  "0 20px 40px {primitives.shadow-color.dark-strong}"
      }
    },

    "border": {
      "thin":   "{primitives.border-width.thin} solid",
      "medium": "{primitives.border-width.medium} solid",
      "thick":  "{primitives.border-width.thick} solid"
    },

    "motion": {
      "hover":   "{primitives.motion.duration-fast} {primitives.motion.ease-standard}",
      "expand":  "{primitives.motion.duration-base} {primitives.motion.ease-emphasized}",
      "fade":    "{primitives.motion.duration-base} {primitives.motion.ease-out}",
      "enter":   "{primitives.motion.duration-base} {primitives.motion.ease-out}",
      "exit":    "{primitives.motion.duration-fast} {primitives.motion.ease-in}"
    }
  }
}